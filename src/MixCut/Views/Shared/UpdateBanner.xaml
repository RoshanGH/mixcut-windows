<UserControl x:Class="MixCut.Views.Shared.UpdateBanner"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Visibility="{Binding HasUpdate, Converter={StaticResource BoolToVisibility}}">
    <Border Padding="14,8">
        <Border.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                <GradientStop Color="#7C3AED" Offset="0"/>
                <GradientStop Color="#2563EB" Offset="1"/>
            </LinearGradientBrush>
        </Border.Background>
        <Grid>
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <TextBlock Text="✨ 发现新版本" Foreground="White" FontSize="12"
                           FontWeight="SemiBold" Margin="0,0,12,0"/>
                <TextBlock Text="{Binding BannerText}" Foreground="White" FontSize="12"
                           VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="立即下载更新" Click="OnDownloadClick"
                        Background="White" Foreground="#7C3AED" BorderThickness="0"
                        Padding="12,4" Cursor="Hand" Margin="0,0,8,0"
                        FontWeight="SemiBold"
                        ToolTip="打开 release 页面下载新版本"/>
                <Button Content="✕" Click="OnDismissClick"
                        Background="Transparent" Foreground="White" BorderThickness="0"
                        Padding="6,2" Cursor="Hand" FontSize="14"
                        ToolTip="屏蔽此版本的提示"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
