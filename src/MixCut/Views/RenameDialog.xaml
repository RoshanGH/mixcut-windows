<Window x:Class="MixCut.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="重命名项目"
        Icon="/Resources/AppIcon.ico" SizeToContent="Height" Width="400" MinHeight="200"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="24">
        <TextBlock Text="重命名项目" FontSize="15" FontWeight="SemiBold"
                   HorizontalAlignment="Center" Margin="0,0,0,16" />
        <TextBlock Text="新名称" FontSize="12" Foreground="#666" Margin="0,0,0,4" />
        <TextBox x:Name="NameBox" Padding="6,5" FontSize="13" />
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
            <Button Content="取消" Padding="18,7" Margin="0,0,10,0" IsCancel="True" />
            <Button x:Name="OkButton" Content="保存" Padding="18,7" IsDefault="True"
                    Background="#1D6BE5" Foreground="White" BorderThickness="0"
                    Click="OnOk" />
        </StackPanel>
    </StackPanel>
</Window>
