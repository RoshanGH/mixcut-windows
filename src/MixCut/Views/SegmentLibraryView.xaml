<UserControl x:Class="MixCut.Views.SegmentLibraryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <DockPanel Margin="20,16,16,16">
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <!-- 搜索框 + 视图切换 + 排序 -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#F2F2F4" CornerRadius="8" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="12" Foreground="#999"
                                   VerticalAlignment="Center" Margin="2,0,6,0" />
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center"
                                 TextChanged="OnSearchChanged" />
                        <Button Grid.Column="2" x:Name="ClearSearchButton" Content="✕"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#999" Padding="4,0" Cursor="Hand"
                                Click="OnClearSearch" Visibility="Collapsed" />
                    </Grid>
                </Border>

                <ComboBox Grid.Column="1" x:Name="ViewModeCombo" Width="86"
                          Margin="8,0,0,0" Padding="6,4"
                          SelectionChanged="OnViewModeChanged">
                    <ComboBoxItem Content="网格" IsSelected="True" />
                    <ComboBoxItem Content="列表" />
                </ComboBox>

                <ComboBox Grid.Column="2" x:Name="SortCombo" Width="96"
                          Margin="8,0,0,0" Padding="6,4"
                          SelectionChanged="OnSortChanged">
                    <ComboBoxItem Content="按时间" IsSelected="True" />
                    <ComboBoxItem Content="按质量" />
                </ComboBox>
            </Grid>

            <!-- 语义类型筛选芯片 -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,6">
                <ItemsControl x:Name="TypeChipList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <!-- 统计 + 重置 + 多选模式开关 -->
            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatsText" FontSize="11" Foreground="#666"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" x:Name="ResetButton" Content="✕  重置筛选" Padding="8,3"
                        Background="#F0F0F2" BorderThickness="0" Foreground="#666"
                        Margin="0,0,8,0" Cursor="Hand"
                        Click="OnResetFilter" Visibility="Collapsed" FontSize="11" />
                <Button Grid.Column="2" x:Name="SelectionModeButton" Content="☑ 多选"
                        Padding="10,3" Cursor="Hand" FontSize="11"
                        Background="White" BorderBrush="#CCC"
                        Click="OnToggleSelectionMode" />
            </Grid>

            <!-- 多选模式工具栏 -->
            <Border x:Name="SelectionToolbar" Background="#E7F0FF" CornerRadius="6"
                    Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="SelectionCountText" Text="已选 0"
                               FontSize="11" FontWeight="SemiBold" Foreground="#1D6BE5"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="全选" Padding="9,3" Margin="0,0,4,0"
                                Background="White" BorderBrush="#CCC" FontSize="11"
                                Cursor="Hand" Click="OnSelectAll" />
                        <Button Content="反选" Padding="9,3" Margin="0,0,4,0"
                                Background="White" BorderBrush="#CCC" FontSize="11"
                                Cursor="Hand" Click="OnInvertSelection" />
                        <Button Content="清空" Padding="9,3" Margin="0,0,12,0"
                                Background="White" BorderBrush="#CCC" FontSize="11"
                                Cursor="Hand" Click="OnClearSelection" />
                        <Button x:Name="CombineSchemeButton" Content="✨ 组合为方案"
                                Padding="12,3" Margin="0,0,4,0"
                                Background="#7C3AED" Foreground="White" BorderThickness="0"
                                FontSize="11" Cursor="Hand" Click="OnCombineSchemeClick"
                                IsEnabled="False"
                                ToolTip="请至少选择 2 个分镜（按勾选顺序生成方案）"
                                ToolTipService.ShowOnDisabled="True" />
                        <Button x:Name="BatchExportButton" Content="⬆ 批量导出"
                                Padding="12,3" Margin="0,0,4,0"
                                Background="#1D6BE5" Foreground="White" BorderThickness="0"
                                FontSize="11" Cursor="Hand" Click="OnBatchExport"
                                IsEnabled="False" />
                        <Button x:Name="BatchDeleteButton" Content="🗑 批量删除"
                                Padding="12,3"
                                Background="White" BorderBrush="#D33A3A" Foreground="#D33A3A"
                                FontSize="11" Cursor="Hand" Click="OnBatchDelete"
                                IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border DockPanel.Dock="Top" Height="1" Background="#EEE" Margin="0,4,0,8" />

        <!-- 内容区（卡片本身已包含全部编辑入口，无需独立详情面板） -->
        <ScrollViewer x:Name="ContentScroller" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="ContentPanel" />
        </ScrollViewer>
    </DockPanel>
</UserControl>
