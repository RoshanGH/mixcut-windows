<Window x:Class="MixCut.Views.KeyboardShortcutsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="键盘快捷键"
        Icon="/Resources/AppIcon.ico" Width="460" Height="560"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <Window.InputBindings>
        <KeyBinding Key="Escape" Command="ApplicationCommands.Close" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="ApplicationCommands.Close" Executed="OnClose" />
    </Window.CommandBindings>
    <DockPanel Margin="24">
        <TextBlock DockPanel.Dock="Top" Text="⌨ 键盘快捷键" FontSize="16" FontWeight="SemiBold"
                   Margin="0,0,0,16" />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="关闭" Padding="18,6" IsDefault="True" Click="OnClose"
                    Style="{StaticResource PrimaryButtonStyle}" />
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="项目" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + N"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="新建项目" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + ,"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="打开设置" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + /"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="显示快捷键帮助" FontSize="11" />
                </Grid>

                <TextBlock Text="工作区导航" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + 1"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="项目概览" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + 2"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="素材导入" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + 3"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="分镜素材库" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl + 4"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="混剪方案" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl + 5"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="4" Grid.Column="1" Text="导出" FontSize="11" />
                </Grid>

                <TextBlock Text="分镜库 · 多选模式" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,6" />
                <Grid Margin="0,0,0,12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl + A"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="全选可见分镜" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl + D"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="反选可见分镜" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl + 0"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="清空选择" FontSize="11"
                               Margin="0,0,0,4" />
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Esc"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="退出多选模式" FontSize="11" />
                </Grid>

                <TextBlock Text="通用" FontSize="11" FontWeight="SemiBold"
                           Foreground="#888" Margin="0,0,0,6" />
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Esc"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="关闭当前对话框 / 取消操作"
                               FontSize="11" Margin="0,0,0,4" />
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Enter"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="确认 / 提交 / 下一步"
                               FontSize="11" Margin="0,0,0,4" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="F2"
                               FontFamily="{StaticResource FontFamilyMono}" FontSize="11" Foreground="{StaticResource AccentBlueBrush}" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="重命名当前项目（侧边栏选中后）"
                               FontSize="11" />
                </Grid>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
