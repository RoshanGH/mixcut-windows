<Window x:Class="MixCut.Views.GenerateSchemeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="批量生成混剪方案"
        Icon="/Resources/AppIcon.ico" SizeToContent="Height" Width="480"
        MinHeight="420"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <StackPanel Margin="26">
        <TextBlock Text="批量生成混剪方案" FontSize="16" FontWeight="SemiBold"
                   HorizontalAlignment="Center" />
        <TextBlock Text="AI 将生成多个策略，每个策略自动排列组合出大量视频"
                   FontSize="11" Foreground="#888" HorizontalAlignment="Center"
                   Margin="0,4,0,18" />

        <!-- 素材概览 -->
        <Border Background="#F5F5F7" CornerRadius="10" Padding="14,12" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                    <TextBlock x:Name="VideoCountText" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="视频" FontSize="10" Foreground="#999"
                               HorizontalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="1" Width="1" Background="#DDD" />
                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                    <TextBlock x:Name="SegmentCountText" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="分镜" FontSize="10" Foreground="#999"
                               HorizontalAlignment="Center" />
                </StackPanel>
                <Border Grid.Column="3" Width="1" Background="#DDD" />
                <StackPanel Grid.Column="4" HorizontalAlignment="Center">
                    <TextBlock x:Name="DurationText" FontSize="18" FontWeight="SemiBold"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="总时长" FontSize="10" Foreground="#999"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 目标视频数 -->
        <Grid Margin="0,0,0,4">
            <TextBlock Text="目标视频数量" FontSize="13" />
            <TextBlock x:Name="TargetCountText" FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Right" />
        </Grid>
        <Slider x:Name="CountSlider" Minimum="10" Maximum="100" Value="50"
                TickFrequency="10" IsSnapToTickEnabled="True"
                ValueChanged="OnSliderChanged" Margin="0,4,0,4" />
        <TextBlock x:Name="EstimateText" FontSize="11" Foreground="#999" Margin="0,2,0,18" />

        <!-- 自定义要求 -->
        <TextBlock Text="自定义需求（可选）" FontSize="13" Margin="0,0,0,4" />
        <Grid>
            <TextBox x:Name="CustomPromptBox" Padding="6,5" Height="56"
                     TextWrapping="Wrap" AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     TextChanged="OnCustomPromptChanged" />
            <TextBlock x:Name="CustomPromptPlaceholder"
                       Text="如：偏重促销风格、时长控制在 30 秒内、避免低质量画面..."
                       Foreground="#BBB" FontSize="12"
                       Margin="9,7,0,0" IsHitTestVisible="False"
                       VerticalAlignment="Top" HorizontalAlignment="Left" />
        </Grid>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="取消" Padding="18,7" Margin="0,0,10,0" IsCancel="True"
                    Background="White" BorderBrush="#CCC" />
            <Button x:Name="StartButton" Content="✨ 开始生成" Padding="18,7" IsDefault="True"
                    Background="#1D6BE5" Foreground="White" BorderThickness="0"
                    Click="OnStart" />
        </StackPanel>
    </StackPanel>
</Window>
