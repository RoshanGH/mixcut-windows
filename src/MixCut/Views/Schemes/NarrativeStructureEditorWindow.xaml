<Window x:Class="MixCut.Views.Schemes.NarrativeStructureEditorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="叙事结构编辑器" Width="580" Height="640"
        WindowStartupLocation="CenterOwner" Background="#F7F7F8"
        ResizeMode="CanResize" MinWidth="480" MinHeight="480">
    <DockPanel Margin="18">
        <!-- 顶部：实时预览名（只读，由段位标签拼接） -->
        <Border DockPanel.Dock="Top" Background="White" CornerRadius="8" Padding="14,10"
                BorderBrush="#E3E3E6" BorderThickness="1" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="结构预览（名字 = 段位标签序列）" FontSize="10" Foreground="#9A9A9F" />
                <TextBlock x:Name="PreviewNameText" Text="（先添加段位）" FontSize="14"
                           FontWeight="SemiBold" Foreground="#1D6BE5" TextWrapping="Wrap"
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- 底部：生成变体数 + 生成按钮 + 进度 -->
        <Border DockPanel.Dock="Bottom" Margin="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="生成变体数" VerticalAlignment="Center"
                           FontSize="12" Foreground="#444" Margin="0,0,8,0" />
                <ComboBox Grid.Column="1" x:Name="VariationCombo" Width="70"
                          VerticalAlignment="Center" SelectedIndex="1">
                    <ComboBoxItem>3</ComboBoxItem>
                    <ComboBoxItem>5</ComboBoxItem>
                    <ComboBoxItem>8</ComboBoxItem>
                    <ComboBoxItem>10</ComboBoxItem>
                </ComboBox>
                <TextBlock Grid.Column="2" x:Name="StatusText" VerticalAlignment="Center"
                           Margin="14,0" FontSize="11" Foreground="#888"
                           TextTrimming="CharacterEllipsis" />
                <Button Grid.Column="3" x:Name="GenerateButton" Content="生成方案"
                        Click="OnGenerateClick" Padding="18,8" FontSize="13" FontWeight="SemiBold"
                        Background="#1D6BE5" Foreground="White" BorderThickness="0" Cursor="Hand" />
            </Grid>
        </Border>

        <!-- 中间：段位列表 + 添加段（滚动） -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="SlotsPanel" />
        </ScrollViewer>
    </DockPanel>
</Window>
