<UserControl x:Class="MixCut.Views.Schemes.InsertGapButton"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent" Cursor="Hand"
             VerticalAlignment="Stretch">
    <!--
        方案 storyboard 分镜卡片之间的 ⊕ 插入按钮（场景 B）。
        默认宽 12px、Opacity 0；hover 时变 28px、Opacity 1。
        UserControl Style Trigger 直接改 Width/Opacity，无 RenderTransform。
    -->
    <UserControl.Style>
        <Style TargetType="UserControl">
            <Setter Property="Width" Value="12"/>
            <Setter Property="Opacity" Value="0.0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Width" Value="28"/>
                    <Setter Property="Opacity" Value="1.0"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Style>
    <Border Background="#1D6BE5" CornerRadius="14" Margin="3"
            MouseLeftButtonUp="OnClick"
            ToolTip="在此处插入分镜">
        <TextBlock Text="+" Foreground="White" FontSize="16" FontWeight="Bold"
                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
    </Border>
</UserControl>
