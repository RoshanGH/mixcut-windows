<UserControl x:Class="MixCut.Views.ProjectOverviewView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="White">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="28" >
            <!-- 标题行 -->
            <Grid Margin="0,0,0,20">
                <StackPanel>
                    <Grid>
                        <TextBlock x:Name="ProjectName" FontSize="24" FontWeight="Bold"
                                   Cursor="IBeam" ToolTip="双击重命名"
                                   MouseLeftButtonDown="OnProjectNameMouseDown" />
                        <TextBox x:Name="ProjectNameEditor" Visibility="Collapsed"
                                 FontSize="24" FontWeight="Bold"
                                 BorderThickness="0" Background="Transparent"
                                 Padding="0" Margin="-2,0,0,0"
                                 LostKeyboardFocus="OnProjectNameEditorLostFocus"
                                 PreviewKeyDown="OnProjectNameEditorKeyDown" />
                    </Grid>
                    <TextBlock x:Name="ProjectCreatedAt" FontSize="11" Foreground="#999"
                               Margin="0,4,0,0" />
                </StackPanel>
                <Border x:Name="StatusBadge" CornerRadius="999" Padding="10,4"
                        HorizontalAlignment="Right" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="StatusDot" Width="6" Height="6" Margin="0,0,5,0"
                                 VerticalAlignment="Center" />
                        <TextBlock x:Name="StatusText" FontSize="11" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 统计卡片 -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="#F5F5F7" CornerRadius="10"
                        Padding="18,16" Margin="0,0,6,0"
                        Cursor="Hand" MouseLeftButtonDown="OnStatCardImport"
                        ToolTip="点击进入素材导入">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="36" Height="36" Background="#E7F0FF" CornerRadius="8"
                                Margin="0,0,0,8">
                            <TextBlock Text="🎞" FontSize="16" Foreground="#1D6BE5"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="VideoCount" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="视频" FontSize="11" Foreground="#999"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Background="#F5F5F7" CornerRadius="10"
                        Padding="18,16" Margin="6,0"
                        Cursor="Hand" MouseLeftButtonDown="OnStatCardSegmentLibrary"
                        ToolTip="点击查看分镜素材库">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="36" Height="36" Background="#E2F5E8" CornerRadius="8"
                                Margin="0,0,0,8">
                            <TextBlock Text="✂" FontSize="16" Foreground="#2E8B57"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="SegmentCount" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="分镜" FontSize="11" Foreground="#999"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Background="#F5F5F7" CornerRadius="10"
                        Padding="18,16" Margin="6,0,0,0"
                        Cursor="Hand" MouseLeftButtonDown="OnStatCardSchemes"
                        ToolTip="点击查看混剪方案">
                    <StackPanel HorizontalAlignment="Center">
                        <Border Width="36" Height="36" Background="#F4E8FF" CornerRadius="8"
                                Margin="0,0,0,8">
                            <TextBlock Text="📋" FontSize="16" Foreground="#9333EA"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock x:Name="SchemeCount" FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <TextBlock Text="方案" FontSize="11" Foreground="#999"
                                   HorizontalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- 快速操作 -->
            <TextBlock Text="快速操作" FontSize="12" FontWeight="SemiBold"
                       Foreground="#666" Margin="0,0,0,8" />
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button Grid.Column="0" x:Name="ImportButton" Click="OnGoImport"
                        Margin="0,0,6,0" Padding="0,14" Cursor="Hand"
                        Background="#E7F0FF" Foreground="#1D6BE5" BorderThickness="0">
                    <StackPanel>
                        <TextBlock Text="⬇" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="导入视频" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="1" x:Name="SchemesButton" Click="OnGoSchemes"
                        Margin="6,0" Padding="0,14" Cursor="Hand"
                        Background="#F4E8FF" Foreground="#9333EA" BorderThickness="0">
                    <StackPanel>
                        <TextBlock Text="✨" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="生成方案" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" x:Name="ExportButton" Click="OnGoExport"
                        Margin="6,0,0,0" Padding="0,14" Cursor="Hand"
                        Background="#E2F5E8" Foreground="#2E8B57" BorderThickness="0">
                    <StackPanel>
                        <TextBlock Text="⬆" FontSize="18" HorizontalAlignment="Center" />
                        <TextBlock Text="导出视频" FontSize="11" FontWeight="SemiBold"
                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                    </StackPanel>
                </Button>
            </Grid>

            <Border Height="1" Background="#EEE" Margin="0,0,0,20" />

            <!-- 视频列表 / 空状态 -->
            <StackPanel x:Name="EmptyState" Visibility="Collapsed">
                <TextBlock Text="🎞" FontSize="36" Foreground="#CCC"
                           HorizontalAlignment="Center" Margin="0,20,0,8" />
                <TextBlock Text="暂无视频素材" FontSize="14" FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <TextBlock Text="导入第一个视频开始你的混剪项目"
                           FontSize="12" Foreground="#888"
                           HorizontalAlignment="Center" Margin="0,4,0,14" />
                <!-- CTA：直接跳转到 Import 工作区，对齐 Mac 空状态的「立即导入」按钮 -->
                <!-- P0-3：全局 PrimaryButtonStyle（蓝底白字 + hover/pressed/圆角），保留自定义 Padding/FontSize -->
                <Button Click="OnGoImport" Padding="22,10" FontSize="13"
                        Style="{StaticResource PrimaryButtonStyle}"
                        HorizontalAlignment="Center" Margin="0,0,0,30">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⬇" FontSize="14" Margin="0,0,6,0" />
                        <TextBlock Text="立即导入视频" />
                    </StackPanel>
                </Button>
            </StackPanel>

            <StackPanel x:Name="VideoListSection" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="已导入视频" FontSize="12" FontWeight="SemiBold"
                               Foreground="#666" />
                    <Border Background="#F0F0F2" CornerRadius="999" Padding="6,1"
                            Margin="6,0,0,0" VerticalAlignment="Center">
                        <TextBlock x:Name="VideoCountBadge" FontSize="10" Foreground="#999" />
                    </Border>
                </StackPanel>
                <WrapPanel x:Name="VideoGrid" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
