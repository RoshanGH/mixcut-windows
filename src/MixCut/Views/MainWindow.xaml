<Window x:Class="MixCut.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MixCut.Views.Converters"
        xmlns:shared="clr-namespace:MixCut.Views.Shared"
        Title="MixCut" Height="760" Width="1200"
        MinHeight="600" MinWidth="960"
        WindowStartupLocation="CenterScreen"
        Icon="/Resources/AppIcon.ico"
        Background="#FFFFFF">
    <Window.Resources>
        <conv:ProjectStatusToColorConverter x:Key="StatusToColorConverter" />
        <conv:ProjectStatusToLabelConverter x:Key="StatusToLabelConverter" />
    </Window.Resources>
    <Window.InputBindings>
        <!-- 项目操作 -->
        <KeyBinding Key="N" Modifiers="Control" Command="{x:Static ApplicationCommands.New}" />
        <KeyBinding Key="OemComma" Modifiers="Control" Command="{x:Static ApplicationCommands.Properties}" />
        <!-- 导航：Ctrl+1~5 切换 5 个工作区 -->
        <KeyBinding Key="D1" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}" />
        <KeyBinding Key="D2" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}" />
        <KeyBinding Key="D3" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}" />
        <KeyBinding Key="D4" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}" />
        <KeyBinding Key="D5" Modifiers="Control" Command="{x:Static ApplicationCommands.NotACommand}" />
        <!-- 快捷键帮助 Ctrl+/ -->
        <KeyBinding Key="OemQuestion" Modifiers="Control" Command="{x:Static ApplicationCommands.Help}" />
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.New}" Executed="OnNewProjectCommand" />
        <CommandBinding Command="{x:Static ApplicationCommands.Properties}" Executed="OnSettingsCommand" />
        <CommandBinding Command="{x:Static ApplicationCommands.Help}" Executed="OnShowShortcutsCommand" />
    </Window.CommandBindings>
    <DockPanel>
        <!-- 顶部「发现新版本」banner（v0.3.1）：默认 Collapsed；UpdateBannerViewModel.HasUpdate=true 时显示 -->
        <shared:UpdateBanner DockPanel.Dock="Top" x:Name="UpdateBannerHost" />

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 侧边栏 -->
        <Border Grid.Column="0" Background="#F5F5F7" BorderBrush="#E0E0E2" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- 标题（点击回到欢迎页） -->
                <Border DockPanel.Dock="Top" Padding="16,14" BorderBrush="#E0E0E2" BorderThickness="0,0,0,1"
                        Cursor="Hand" MouseLeftButtonDown="OnLogoClick">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="MixCut" FontSize="15" FontWeight="Bold" Foreground="#1D6BE5" />
                        <!-- 依赖未配置警告（橙色 ⚠ + tooltip） -->
                        <Border x:Name="DepsWarningBadge" Grid.Column="1"
                                Background="#FFF1DC" CornerRadius="999" Padding="6,2"
                                Visibility="Collapsed" Cursor="Hand"
                                MouseLeftButtonDown="OnDepsWarningClick"
                                ToolTip="依赖未配置（点击查看）">
                            <TextBlock Text="⚠" FontSize="11" Foreground="#C06F00"
                                       FontWeight="Bold" />
                        </Border>
                    </Grid>
                </Border>

                <!-- 设置按钮 -->
                <Button DockPanel.Dock="Bottom" x:Name="SettingsButton" Content="⚙  设置"
                        Margin="12,8" Padding="8,6" HorizontalContentAlignment="Left"
                        Background="Transparent" BorderThickness="0" Cursor="Hand"
                        Click="OnSettingsClick" />

                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="12,8">
                        <TextBlock Text="项目" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#999" Margin="8,4" />
                        <ListBox x:Name="ProjectList" BorderThickness="0" Background="Transparent"
                                 SelectionChanged="OnProjectSelected"
                                 MouseDoubleClick="OnProjectDoubleClick"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="6,5" />
                                    <Setter Property="Margin" Value="0,1" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="🎞" FontSize="11"
                                                   Margin="0,0,8,0" Opacity="0.55"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                   TextTrimming="CharacterEllipsis"
                                                   VerticalAlignment="Center" />
                                        <Border Grid.Column="2" Width="6" Height="6"
                                                CornerRadius="999" Margin="6,0,2,0"
                                                VerticalAlignment="Center"
                                                ToolTip="{Binding Status, Converter={StaticResource StatusToLabelConverter}}"
                                                Background="{Binding Status, Converter={StaticResource StatusToColorConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="重命名…" Click="OnRenameProject" />
                                    <MenuItem Header="归档" Click="OnArchiveProject" />
                                    <Separator />
                                    <MenuItem Header="删除" Click="OnDeleteProject" />
                                </ContextMenu>
                            </ListBox.ContextMenu>
                        </ListBox>
                        <Button x:Name="NewProjectButton" Content="＋  新建项目"
                                Margin="0,4" Padding="8,6" HorizontalContentAlignment="Left"
                                Background="Transparent" BorderThickness="0"
                                Foreground="#1D6BE5" Cursor="Hand" Click="OnNewProjectClick" />

                        <TextBlock Text="工作区" FontSize="10" FontWeight="SemiBold"
                                   Foreground="#999" Margin="8,16,8,4" />
                        <ListBox x:Name="NavList" BorderThickness="0" Background="Transparent"
                                 SelectionChanged="OnNavSelected">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" Padding="4,5" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- 内容区 -->
        <ContentControl Grid.Column="1" x:Name="ContentArea" />

        <!-- Toast 浮层（跨整个窗口，z 序最高，IsHitTest=False 不拦截点击） -->
        <Grid Grid.ColumnSpan="2" x:Name="ToastHost" IsHitTestVisible="False" />
    </Grid>
    </DockPanel>
</Window>
