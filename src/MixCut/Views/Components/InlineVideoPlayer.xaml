<UserControl x:Class="MixCut.Views.Components.InlineVideoPlayer"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:components="clr-namespace:MixCut.Views.Components"
             Background="Black">
    <Grid x:Name="RootGrid">
        <!-- 缩略图态 -->
        <Grid x:Name="ThumbnailState">
            <Image x:Name="ThumbImage" Stretch="Uniform" />
            <Border Background="#40000000" />
            <Button x:Name="PlayButton" Click="OnPlayClick"
                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                    HorizontalAlignment="Center" VerticalAlignment="Center">
                <Border Background="#90000000" CornerRadius="999" Width="38" Height="38">
                    <TextBlock Text="▶" Foreground="White" FontSize="14"
                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
            </Button>
            <!-- 缩略图右下角时长角标 -->
            <Border x:Name="DurationBadge" Background="#A0000000" CornerRadius="4"
                    Padding="6,1" Margin="0,0,6,6" Visibility="Collapsed"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBlock x:Name="DurationBadgeText" Foreground="White"
                           FontSize="10" FontWeight="SemiBold" />
            </Border>
        </Grid>

        <!-- 播放态 -->
        <Grid x:Name="PlayingState" Visibility="Collapsed">
            <components:FfmpegFramePlayer x:Name="Player" Stretch="Uniform"
                          Opened="OnMediaOpened" Ended="OnMediaEnded" Failed="OnMediaFailed" />
            <!-- 控制栏 -->
            <Border VerticalAlignment="Bottom" Background="#A0000000" Padding="6,3">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" x:Name="PauseButton" Click="OnPauseClick"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            Width="22" Height="22" FontSize="11" Content="⏸" />
                    <TextBlock Grid.Column="1" x:Name="CurrentTimeText" Text="0:00"
                               Foreground="White" FontSize="9" VerticalAlignment="Center"
                               Margin="4,0,8,0" />
                    <Slider Grid.Column="2" x:Name="ProgressSlider" Minimum="0" Maximum="1"
                            VerticalAlignment="Center"
                            Thumb.DragStarted="OnSliderDragStart"
                            Thumb.DragCompleted="OnSliderDragEnd"
                            ValueChanged="OnSliderValueChanged" />
                    <TextBlock Grid.Column="3" x:Name="DurationText" Text="0:00"
                               Foreground="White" FontSize="9" VerticalAlignment="Center"
                               Margin="8,0,4,0" />
                    <Button Grid.Column="4" x:Name="StopButton" Click="OnStopClick"
                            Background="Transparent" BorderThickness="0" Foreground="White"
                            Width="22" Height="22" FontSize="11" Content="✕" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
