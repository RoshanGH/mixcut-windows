<UserControl x:Class="MixCut.Views.SegmentLibraryViewV2"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:cards="clr-namespace:MixCut.ViewModels.Cards"
             xmlns:comp="clr-namespace:MixCut.Views.Components"
             xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d"
             Background="{StaticResource BgPrimaryBrush}">
    <UserControl.Resources>
        <sys:Double x:Key="SegmentCardWidth">228</sys:Double>
        <sys:Double x:Key="SegmentCardHeight">650</sys:Double>
        <!-- 卡片内满宽 9:16，避免视频缩在大面积空白中。 -->
        <sys:Double x:Key="SegmentCardThumbWidth">210</sys:Double>
        <sys:Double x:Key="SegmentCardThumbHeight">373</sys:Double>

        <Style x:Key="FrameStepButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28" />
            <Setter Property="Height" Value="28" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
            <Setter Property="Background" Value="{StaticResource AccentBlueLightBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource AccentBlueHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background"
                                        Value="{StaticResource AccentBlueAlpha20Brush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <DockPanel x:Name="RootDock" Margin="20,16,16,16">

        <!-- ========== 顶部工具栏 ========== -->
        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Background="{StaticResource BgQuaternaryBrush}"
                        CornerRadius="{StaticResource CornerRadiusMd}" Padding="8,4">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🔍" FontSize="12"
                                   Foreground="{StaticResource TextQuaternaryBrush}"
                                   VerticalAlignment="Center" Margin="2,0,6,0" />
                        <TextBox Grid.Column="1" x:Name="SearchBox"
                                 BorderThickness="0" Background="Transparent"
                                 VerticalAlignment="Center" FontSize="12"
                                 TextChanged="OnSearchChanged" />
                        <Button Grid.Column="2" x:Name="ClearSearchButton" Content="✕"
                                Background="Transparent" BorderThickness="0"
                                Foreground="{StaticResource TextQuaternaryBrush}"
                                Padding="4,0" Cursor="Hand" Visibility="Collapsed"
                                Click="OnClearSearch" />
                    </Grid>
                </Border>

                <ComboBox Grid.Column="1" x:Name="ViewModeCombo" Width="86" Margin="8,0,0,0"
                          Padding="6,4" SelectionChanged="OnViewModeChanged">
                    <ComboBoxItem Content="网格" IsSelected="True" />
                    <ComboBoxItem Content="列表" />
                </ComboBox>

                <ComboBox Grid.Column="2" x:Name="SortCombo" Width="96" Margin="8,0,0,0"
                          Padding="6,4" SelectionChanged="OnSortChanged">
                    <ComboBoxItem Content="按时间" IsSelected="True" />
                    <ComboBoxItem Content="按质量" />
                </ComboBox>
            </Grid>

            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled"
                          Margin="0,0,0,6">
                <ItemsControl x:Name="TypeChipList">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <Grid Margin="0,4,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatsText" FontSize="11"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           VerticalAlignment="Center" />
                <Button Grid.Column="1" x:Name="ResetButton" Content="✕  重置筛选"
                        Background="{StaticResource BgTertiaryBrush}"
                        Foreground="{StaticResource TextTertiaryBrush}"
                        BorderThickness="0" Padding="8,3" Margin="0,0,8,0"
                        FontSize="11" Cursor="Hand"
                        Click="OnResetFilter" Visibility="Collapsed" />
                <Button Grid.Column="2" x:Name="SelectionModeButton" Content="☑ 多选"
                        Background="White"
                        BorderBrush="{StaticResource BorderHoverBrush}"
                        BorderThickness="1" Padding="10,3"
                        FontSize="11" Cursor="Hand"
                        Click="OnToggleSelectionMode" />
            </Grid>

            <Border x:Name="SelectionToolbar" Background="{StaticResource AccentBlueLightBrush}"
                    CornerRadius="6" Padding="10,6" Margin="0,8,0,0" Visibility="Collapsed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" x:Name="SelectionCountText" Text="已选 0"
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBlueBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <Button Content="全选" Click="OnSelectAll"
                                Background="White" BorderBrush="{StaticResource BorderHoverBrush}"
                                BorderThickness="1" Padding="9,3" Margin="0,0,4,0"
                                FontSize="11" Cursor="Hand" />
                        <Button Content="反选" Click="OnInvertSelection"
                                Background="White" BorderBrush="{StaticResource BorderHoverBrush}"
                                BorderThickness="1" Padding="9,3" Margin="0,0,4,0"
                                FontSize="11" Cursor="Hand" />
                        <Button Content="清空" Click="OnClearSelection"
                                Background="White" BorderBrush="{StaticResource BorderHoverBrush}"
                                BorderThickness="1" Padding="9,3" Margin="0,0,12,0"
                                FontSize="11" Cursor="Hand" />
                        <Button x:Name="CombineSchemeButton" Content="✨ 组合为方案"
                                Background="{StaticResource PurpleAccentBrush}" Foreground="White"
                                BorderThickness="0"
                                Padding="12,3" Margin="0,0,4,0"
                                FontSize="11" Cursor="Hand"
                                IsEnabled="False"
                                Click="OnCombineSchemeClick"
                                ToolTip="请至少选择 2 个分镜（按勾选顺序生成方案）"
                                ToolTipService.ShowOnDisabled="True">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="r" Property="Background" Value="{StaticResource PurpleAccentDarkBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="r" Property="Opacity" Value="0.55"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BatchExportButton" Content="⬆ 批量导出"
                                Background="{StaticResource AccentBlueBrush}"
                                Foreground="White" BorderThickness="0"
                                Padding="12,3" Margin="0,0,4,0"
                                FontSize="11" Cursor="Hand"
                                Click="OnBatchExport" IsEnabled="False">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border x:Name="r" Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="r" Property="Background" Value="{StaticResource AccentBlueDarkBrush}"/>
                                        </Trigger>
                                        <Trigger Property="IsEnabled" Value="False">
                                            <Setter TargetName="r" Property="Opacity" Value="0.55"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button x:Name="BatchDeleteButton" Content="🗑 批量删除"
                                Background="White"
                                BorderBrush="{StaticResource DangerRedBrush}"
                                Foreground="{StaticResource DangerRedBrush}"
                                BorderThickness="1" Padding="12,3"
                                FontSize="11" Cursor="Hand"
                                Click="OnBatchDelete" IsEnabled="False" />
                    </StackPanel>
                </Grid>
            </Border>
        </StackPanel>

        <Border DockPanel.Dock="Top" Height="1"
                Background="{StaticResource BorderSubtleBrush}" Margin="0,4,0,8" />

        <!-- ========== 主体：VirtualizingWrapPanel 真虚拟化（视口外不实例化） ==========
             2 列：col0=配音检视器(Auto，隐藏时 0 宽)，col1=分镜区(*)。检视器左置因本 content 区
             右对齐内容会被推出屏幕外(见 task #13)，左侧 drawer 是当前可靠渲染方案。 -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="EmptyState" Grid.Column="1" Visibility="Collapsed"
                        HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="🎬" FontSize="40"
                           Foreground="{StaticResource TextDisabledBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="没有符合条件的分镜" FontSize="13"
                           Foreground="{StaticResource TextTertiaryBrush}"
                           HorizontalAlignment="Center" Margin="0,8,0,4" />
            </StackPanel>

            <!-- 外层：按视频分组（对齐 Mac 版）。每组 = 视频 header + 该组分镜 WrapPanel -->
            <ScrollViewer x:Name="GroupsScroller" Grid.Column="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="GroupsHost" ItemsSource="{Binding Groups}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type cards:VideoGroupViewModel}">
                            <StackPanel Margin="0,0,0,18">
                                <!-- 视频 header：缩略图 + 名称 + 分镜数 -->
                                <Border Margin="0,0,0,10" Padding="8,6"
                                        Background="{StaticResource BgSubtleBrush}"
                                        CornerRadius="8">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Width="40" Height="40" CornerRadius="6"
                                                ClipToBounds="True" Background="Black"
                                                Margin="0,0,10,0">
                                            <Image Source="{Binding ThumbnailImage}"
                                                   Stretch="UniformToFill" />
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="{Binding VideoName}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       TextTrimming="CharacterEllipsis" MaxWidth="700" />
                                            <TextBlock Text="{Binding MetaText}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextTertiaryBrush}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                <!-- 配音设置条（v0.5.0，每视频独立）：状态区 + 变体数 stepper + 克隆并改写按钮。
                                     左对齐（分镜 WrapPanel 会把组撑宽，右对齐内容会被推出可见区外）。 -->
                                <Grid Margin="0,0,0,10" MinHeight="30" HorizontalAlignment="Left">
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <!-- 主按钮 -->
                                        <Button Content="{Binding DubMainButtonText}" Command="{Binding RewriteAllCommand}"
                                                IsEnabled="{Binding IsNotDubBusy}" Cursor="Hand"
                                                Background="{StaticResource AccentBlueBrush}" Foreground="White"
                                                BorderThickness="0" Padding="12,6" FontSize="12" FontWeight="SemiBold"
                                                VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <!-- 变体数 stepper ×N -->
                                        <Border Background="{StaticResource BgSubtleBrush}" CornerRadius="6" Padding="2"
                                                Margin="0,0,10,0" VerticalAlignment="Center"
                                                IsEnabled="{Binding IsNotDubBusy}">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="−" Style="{StaticResource FrameStepButtonStyle}"
                                                        ToolTip="减少变体数" Command="{Binding DecVariantCommand}" />
                                                <TextBlock VerticalAlignment="Center" MinWidth="28" TextAlignment="Center"
                                                           FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}">
                                                    <Run Text="×" /><Run Text="{Binding VariantCount, Mode=OneWay}" />
                                                </TextBlock>
                                                <Button Content="+" Style="{StaticResource FrameStepButtonStyle}"
                                                        ToolTip="增加变体数（每分镜产出几套改写版）" Command="{Binding IncVariantCommand}" />
                                            </StackPanel>
                                        </Border>
                                        <!-- 忙碌进度 -->
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center"
                                                    Visibility="{Binding IsDubBusy, Converter={StaticResource BoolToVisibility}}">
                                            <TextBlock Text="⏳" FontSize="12" Margin="0,0,4,0" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding DubProgress}" FontSize="11"
                                                       Foreground="{StaticResource AccentBlueBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                        <!-- 空闲状态「✓ N 个变体」 -->
                                        <TextBlock Text="{Binding DubStatusText}" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{StaticResource SuccessGreenBrush}" VerticalAlignment="Center"
                                                   Visibility="{Binding IsDubBusy, Converter={StaticResource InverseBoolToVisibility}}" />
                                    </StackPanel>
                                </Grid>
                                <!-- 该组分镜卡片：WrapPanel 排列（每组小规模，不需要 VirtualizingWrapPanel） -->
                                <ItemsControl ItemsSource="{Binding Segments}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="Margin" Value="0,0,10,10" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type cards:SegmentCardViewModel}">
                        <Border x:Name="CardRoot"
                                Width="{StaticResource SegmentCardWidth}"
                                Height="{StaticResource SegmentCardHeight}"
                                Background="White"
                                BorderBrush="{StaticResource BorderPrimaryBrush}"
                                BorderThickness="1"
                                CornerRadius="10" Padding="8"
                                Cursor="Hand"
                                ClipToBounds="True"
                                Tag="{Binding}"
                                RenderTransformOrigin="0.5,0.5"
                                MouseLeftButtonDown="OnCardClicked"
                                MouseEnter="OnCardMouseEnter"
                                MouseLeave="OnCardMouseLeave">
                            <!-- P0-6：hover 时卡片 subtle 缩放浮起（纯 RenderTransform，不碰画刷，零冻结崩溃风险） -->
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Border.RenderTransform>
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="📋 复制台词"
                                              Command="{Binding PlacementTarget.Tag.CopyTranscriptCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <MenuItem Header="📂 在 Explorer 中显示原视频"
                                              Command="{Binding PlacementTarget.Tag.ShowInExplorerCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                    <Separator />
                                    <MenuItem Header="🗑 删除分镜"
                                              Command="{Binding PlacementTarget.Tag.DeleteCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                                </ContextMenu>
                            </Border.ContextMenu>

                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueAlpha10Brush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                            <Setter Property="BorderThickness" Value="1.5" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource AccentBlueAlpha20Brush}" />
                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                                            <Setter Property="BorderThickness" Value="2" />
                                        </DataTrigger>
                                        <!-- P0-6：hover 缩放浮起 120ms（EnterActions 放大 / ExitActions 复位） -->
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                         To="1.03" Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                         To="1.03" Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleX"
                                                                         To="1" Duration="0:0:0.12" />
                                                        <DoubleAnimation Storyboard.TargetProperty="RenderTransform.ScaleY"
                                                                         To="1" Duration="0:0:0.12" />
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>

                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />  <!-- 缩略图 -->
                                    <RowDefinition Height="Auto" />  <!-- 标签 -->
                                    <RowDefinition Height="Auto" />  <!-- 位置/质量 -->
                                    <RowDefinition Height="*" />     <!-- 台词（占剩余，超出滚动） -->
                                    <RowDefinition Height="Auto" />  <!-- 边界微调 -->
                                </Grid.RowDefinitions>
                                <!-- 缩略图区 -->
                                <Border Grid.Row="0"
                                        Width="{StaticResource SegmentCardThumbWidth}"
                                        Height="{StaticResource SegmentCardThumbHeight}"
                                        Background="Black"
                                        CornerRadius="6" ClipToBounds="True">
                                    <Grid x:Name="ThumbGrid">
                                        <Image Source="{Binding PreviewImage}" Stretch="UniformToFill" />
                                        <!-- 注入的 InlineVideoPlayer 必须撑满 152x270 框：ContentControl 默认内容对齐 Left/Top
                                             会让 player 缩到内容尺寸（hover 播放不铺满的结构性根因），显式 Stretch 撑满。 -->
                                        <ContentControl x:Name="VideoHost"
                                                        HorizontalContentAlignment="Stretch"
                                                        VerticalContentAlignment="Stretch" />

                                        <!-- 编号徽章（左上） -->
                                        <Border Background="#C01D6BE5" CornerRadius="4"
                                                Padding="5,1"
                                                HorizontalAlignment="Left" VerticalAlignment="Top"
                                                Margin="6,6,0,0">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding SequenceNumber}" Value="0">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Foreground="White" FontSize="10" FontWeight="Bold"
                                                       FontFamily="{StaticResource FontFamilyMono}">
                                                <Run Text="#" /><Run Text="{Binding SequenceNumber, Mode=OneWay}" />
                                            </TextBlock>
                                        </Border>

                                        <!-- 时长 badge（右下，走 binding 自动联动）。hover 播放时隐藏，
                                             避免挡住播放控制栏右侧的总时长数字（OnCardMouseEnter/Leave 切换）。 -->
                                        <Border x:Name="CardDurationBadge"
                                                Background="#A0000000" CornerRadius="4"
                                                Padding="6,1"
                                                HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                Margin="0,0,6,6"
                                                ToolTip="{Binding TimeRangeDisplay}">
                                            <TextBlock Text="{Binding DurationDisplay}"
                                                       Foreground="White" FontSize="10"
                                                       FontWeight="SemiBold" />
                                        </Border>

                                        <!-- 多选标记（右上） -->
                                        <Border Width="24" Height="24"
                                                BorderBrush="#C01D6BE5" BorderThickness="2"
                                                CornerRadius="999"
                                                HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,6,6,0"
                                                Visibility="{Binding IsSelectionMode, Converter={StaticResource BoolToVisibility}}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#A0FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsChecked}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="✓" Foreground="White"
                                                       FontSize="14" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Visibility="{Binding IsChecked, Converter={StaticResource BoolToVisibility}}" />
                                        </Border>

                                        <!-- 全局点击播放：整张缩略图都是点击区（点哪都能播，不用瞄准小 ▶），
                                             居中显示 ▶ 提示。播放时由 OnSegmentPlayClick 隐藏、播完/停止由 Idle 还原。
                                             多选模式隐藏，让点击落到卡片做选择。自定义模板=纯透明背景，避免默认按钮 chrome。 -->
                                        <Button x:Name="PlayOverlay" Click="OnSegmentPlayClick" Tag="{Binding}"
                                                Cursor="Hand"
                                                Visibility="{Binding IsSelectionMode, Converter={StaticResource InverseBoolToVisibility}}">
                                            <Button.Template>
                                                <ControlTemplate TargetType="Button">
                                                    <Border Background="#01000000">
                                                        <ContentPresenter HorizontalAlignment="Center"
                                                                          VerticalAlignment="Center" />
                                                    </Border>
                                                </ControlTemplate>
                                            </Button.Template>
                                            <Border Background="#90000000" CornerRadius="999" Width="46" Height="46">
                                                <TextBlock Text="▶" Foreground="White" FontSize="16"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Margin="3,0,0,0" />
                                            </Border>
                                        </Button>
                                    </Grid>
                                </Border>

                                <!-- 标签 + 位置 + 质量分 -->
                                <ItemsControl Grid.Row="1" ItemsSource="{Binding SemanticTypes}" Margin="0,6,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="999" Padding="7,2" Margin="0,0,4,4"
                                                    Background="{Binding ., Converter={StaticResource SemanticTypeToTintBrush}}">
                                                <TextBlock Text="{Binding ., Converter={StaticResource SemanticTypeToLabel}}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{Binding ., Converter={StaticResource SemanticTypeToBrush}}" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <WrapPanel Grid.Row="2">
                                    <Border CornerRadius="999" Padding="7,2" Margin="0,0,4,4"
                                            Background="#15888888">
                                        <TextBlock Text="{Binding PositionType, Converter={StaticResource PositionTypeToLabel}}"
                                                   FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextTertiaryBrush}" />
                                    </Border>
                                    <Border CornerRadius="999" Padding="7,2" Margin="0,0,4,4"
                                            Background="#152E8B57">
                                        <TextBlock FontSize="10" FontWeight="SemiBold"
                                                   Foreground="{Binding QualityScore, Converter={StaticResource QualityScoreToBrush}}">
                                            <Run Text="★ " /><Run Text="{Binding QualityScore, Mode=OneWay, StringFormat={}{0:F1}}" />
                                        </TextBlock>
                                    </Border>
                                </WrapPanel>

                                <!-- 台词块（占 Row="*" 剩余空间，超出自动滚动） -->
                                <Border Grid.Row="3"
                                        Background="{StaticResource BgSubtleBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6" Padding="7,5" Margin="0,6,0,0">
                                    <Grid>
                                        <!-- 有台词：标题行 + ScrollViewer 自动占剩余 -->
                                        <DockPanel Visibility="{Binding HasTranscript, Converter={StaticResource BoolToVisibility}}">
                                            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,3">
                                                <TextBlock Text="💬" FontSize="9"
                                                           VerticalAlignment="Center" Margin="0,0,4,0" />
                                                <TextBlock Text="台词" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextTertiaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <TextBlock FontSize="9"
                                                           FontFamily="{StaticResource FontFamilyMono}"
                                                           Foreground="{StaticResource TextQuaternaryBrush}"
                                                           VerticalAlignment="Center" Margin="2,0,0,0">
                                                    <Run Text=" · " /><Run Text="{Binding TranscriptCharCount, Mode=OneWay}" /><Run Text="字" />
                                                </TextBlock>
                                            </StackPanel>
                                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <TextBlock Text="{Binding TranscriptText}"
                                                           FontSize="11" TextWrapping="Wrap"
                                                           LineHeight="16"
                                                           Foreground="{StaticResource TextSecondaryBrush}" />
                                            </ScrollViewer>
                                        </DockPanel>
                                        <!-- 无台词：居中提示 -->
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center"
                                                    Visibility="{Binding HasTranscript, Converter={StaticResource BoolToVisibilityInverse}}">
                                            <TextBlock Text="🔇" FontSize="11"
                                                       Foreground="{StaticResource TextQuinaryBrush}"
                                                       Margin="0,0,4,0" />
                                            <TextBlock Text="暂无台词" FontSize="10"
                                                       Foreground="{StaticResource TextQuaternaryBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- 商用级帧边界面板：时间码清楚、按钮可点、最后一帧可核对。 -->
                                <Border Grid.Row="4" Margin="0,8,0,0" Padding="8"
                                        Background="{StaticResource BgSubtleBrush}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="1" CornerRadius="8">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,6">
                                            <TextBlock Text="帧边界" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock HorizontalAlignment="Right"
                                                       Text="{Binding FrameRateDisplay}"
                                                       FontSize="9"
                                                       Foreground="{StaticResource TextQuaternaryBrush}" />
                                        </Grid>

                                        <Grid Margin="0,0,0,5">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="28" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="IN" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBlueBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="−"
                                                    Style="{StaticResource FrameStepButtonStyle}"
                                                    ToolTip="起点向前一帧"
                                                    Command="{Binding AdjustStartCommand}"
                                                    CommandParameter="-1" />
                                            <Border Grid.Column="2" Height="28" Margin="5,0"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="{Binding StartTimecode}"
                                                           FontFamily="{StaticResource FontFamilyMono}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <Button Grid.Column="3" Content="+"
                                                    Style="{StaticResource FrameStepButtonStyle}"
                                                    ToolTip="起点向后一帧"
                                                    Command="{Binding AdjustStartCommand}"
                                                    CommandParameter="1" />
                                        </Grid>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="28" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="OUT" FontSize="9" FontWeight="Bold"
                                                       Foreground="{StaticResource AccentBlueBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button Grid.Column="1" Content="−"
                                                    Style="{StaticResource FrameStepButtonStyle}"
                                                    ToolTip="终点向前一帧"
                                                    Command="{Binding AdjustEndCommand}"
                                                    CommandParameter="-1" />
                                            <Border Grid.Column="2" Height="28" Margin="5,0"
                                                    Background="White"
                                                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                                                    BorderThickness="1" CornerRadius="6">
                                                <TextBlock Text="{Binding EndTimecode}"
                                                           FontFamily="{StaticResource FontFamilyMono}"
                                                           FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           ToolTip="结束边界不包含；实际最后画面见下方" />
                                            </Border>
                                            <Button Grid.Column="3" Content="+"
                                                    Style="{StaticResource FrameStepButtonStyle}"
                                                    ToolTip="终点向后一帧"
                                                    Command="{Binding AdjustEndCommand}"
                                                    CommandParameter="1" />
                                        </Grid>

                                        <Grid Margin="0,7,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock FontSize="9"
                                                       Foreground="{StaticResource TextTertiaryBrush}">
                                                <Run Text="停在最后一帧  " />
                                                <Run Text="{Binding LastFrameTimecode, Mode=OneWay}"
                                                     FontFamily="{StaticResource FontFamilyMono}"
                                                     FontWeight="SemiBold" />
                                            </TextBlock>
                                            <Button x:Name="QuickEditBtn" Grid.Column="1"
                                                    HorizontalAlignment="Right"
                                                    Content="更多"
                                                    Style="{StaticResource GhostButtonStyle}"
                                                    Padding="6,1" FontSize="9"
                                                    Tag="{Binding}"
                                                    Click="OnQuickEditClick" />
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <!-- ========== 配音变体检视器（v0.5.0）：单击分镜后左侧 drawer ========== -->
            <Border Grid.Column="0" VerticalAlignment="Stretch" Width="340" Margin="0,0,12,0"
                    DataContext="{Binding DubInspector}"
                    Visibility="{Binding IsVisible, Converter={StaticResource BoolToVisibility}, FallbackValue=Collapsed}"
                    Background="#16161A" CornerRadius="10">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="16" ShadowDepth="0" Opacity="0.4" Color="Black" />
                </Border.Effect>
                <DockPanel Margin="14,12">
                    <!-- 头部 -->
                    <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🎙" FontSize="14" Margin="0,0,6,0" />
                                <TextBlock Text="配音变体池" FontSize="14" FontWeight="SemiBold" Foreground="White" />
                            </StackPanel>
                            <TextBlock Text="{Binding HeaderSubtitle}" FontSize="11" Foreground="#909090" Margin="0,2,0,0" />
                        </StackPanel>
                        <Button Content="✕" Command="{Binding CloseCommand}" HorizontalAlignment="Right" VerticalAlignment="Top"
                                Background="Transparent" Foreground="#B0B0B0" BorderThickness="0" Cursor="Hand"
                                FontSize="14" Padding="6,0" ToolTip="关闭" />
                    </Grid>

                    <!-- 保留原声态 -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,40,0,0" HorizontalAlignment="Center"
                                Visibility="{Binding IsLocked, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="🔒" FontSize="34" HorizontalAlignment="Center" />
                        <TextBlock Text="保留原声（明星出镜锁定，不参与配音）" FontSize="12" Foreground="#B0B0B0"
                                   TextWrapping="Wrap" TextAlignment="Center" Margin="0,8,0,0" MaxWidth="260" />
                    </StackPanel>

                    <!-- 空白态 -->
                    <StackPanel DockPanel.Dock="Top" Margin="0,30,0,0" HorizontalAlignment="Center"
                                Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="🪄" FontSize="34" HorizontalAlignment="Center" />
                        <TextBlock Text="还没有改写版。点视频上方「克隆并改写配音」批量生成，或手动写一版。"
                                   FontSize="12" Foreground="#B0B0B0" TextWrapping="Wrap" TextAlignment="Center"
                                   Margin="0,8,0,12" MaxWidth="260" />
                        <Button Content="+ 手动添加一版（自己写台词）" Command="{Binding AddManualCommand}"
                                IsEnabled="{Binding IsNotBusy}" Cursor="Hand" Padding="10,6" FontSize="12"
                                Background="{StaticResource AccentBlueBrush}" Foreground="White" BorderThickness="0" />
                    </StackPanel>

                    <!-- 变体池态 -->
                    <Grid Visibility="{Binding IsPool, Converter={StaticResource BoolToVisibility}}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- 重新改写栏 -->
                        <StackPanel Grid.Row="0" Margin="0,0,0,8">
                            <Button Content="↻ 重新改写本分镜" Command="{Binding RewriteSegmentCommand}"
                                    IsEnabled="{Binding IsNotBusy}" Cursor="Hand" Padding="8,5" FontSize="12"
                                    HorizontalAlignment="Stretch" Background="#2A2A33" Foreground="White" BorderThickness="0" />
                            <TextBlock Text="改了原台词后，点此用新原文重写本分镜" FontSize="10"
                                       Foreground="#808080" Margin="0,4,0,0" TextWrapping="Wrap" />
                        </StackPanel>

                        <!-- 变体卡列表 -->
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding Variants}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#1E1E24" CornerRadius="8" Padding="10" Margin="0,0,0,8">
                                            <StackPanel>
                                                <!-- 卡头：字母胶囊 + 字数提示 + 编辑/删除 -->
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Grid.Column="0" Background="{StaticResource AccentBlueBrush}"
                                                            CornerRadius="4" Padding="6,1" VerticalAlignment="Center">
                                                        <TextBlock Foreground="White" FontSize="11" FontWeight="Bold">
                                                            <Run Text="改写版 " /><Run Text="{Binding VariantLetter, Mode=OneWay}" />
                                                        </TextBlock>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{Binding CharCountText}" FontSize="10"
                                                               VerticalAlignment="Center" Margin="8,0,0,0"
                                                               ToolTip="{Binding CharCountHint}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#909090" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding CharCountLevel}" Value="warn">
                                                                        <Setter Property="Foreground" Value="#FF6B6B" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding CharCountLevel}" Value="short">
                                                                        <Setter Property="Foreground" Value="#FFA94D" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                                                        <Button Content="✏" Command="{Binding EditCommand}" ToolTip="编辑台词"
                                                                Background="Transparent" Foreground="#B0B0B0" BorderThickness="0"
                                                                Cursor="Hand" Padding="4,0" FontSize="12" />
                                                        <Button Content="🗑" Command="{Binding DeleteCommand}" ToolTip="删除此版"
                                                                Background="Transparent" Foreground="#B0B0B0" BorderThickness="0"
                                                                Cursor="Hand" Padding="4,0" FontSize="12" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                                Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}">
                                                        <Button Content="✕" Command="{Binding CancelEditCommand}" ToolTip="取消"
                                                                Background="Transparent" Foreground="#B0B0B0" BorderThickness="0"
                                                                Cursor="Hand" Padding="4,0" FontSize="12" />
                                                        <Button Content="✓" Command="{Binding SaveEditCommand}" ToolTip="保存并重新生成"
                                                                Background="Transparent" Foreground="{StaticResource SuccessGreenBrush}"
                                                                BorderThickness="0" Cursor="Hand" Padding="4,0" FontSize="12" />
                                                    </StackPanel>
                                                </Grid>

                                                <!-- 台词正文（显示态） -->
                                                <TextBlock Text="{Binding RewrittenText}" Foreground="#E0E0E0" FontSize="12"
                                                           TextWrapping="Wrap" Margin="0,8,0,0"
                                                           Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}" />
                                                <!-- 台词正文（编辑态） -->
                                                <TextBox Text="{Binding EditingText, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" TextWrapping="Wrap" MinHeight="60" Margin="0,8,0,0"
                                                         Background="#0E0E12" Foreground="White" BorderBrush="#3A3A44"
                                                         Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}" />

                                                <!-- 生成/播放控件 -->
                                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0"
                                                            Visibility="{Binding IsEditing, Converter={StaticResource InverseBoolToVisibility}}">
                                                    <!-- 未生成：生成按钮 -->
                                                    <Button Content="生成" Command="{Binding GenerateCommand}"
                                                            Visibility="{Binding HasAudio, Converter={StaticResource InverseBoolToVisibility}}"
                                                            Background="{StaticResource AccentBlueBrush}" Foreground="White" BorderThickness="0"
                                                            Cursor="Hand" Padding="10,4" FontSize="11" />
                                                    <!-- 已生成：播放 + 重新生成 + 时长 -->
                                                    <Button Command="{Binding PlayCommand}"
                                                            Visibility="{Binding HasAudio, Converter={StaticResource BoolToVisibility}}"
                                                            Background="{StaticResource SuccessGreenBrush}" Foreground="White" BorderThickness="0"
                                                            Cursor="Hand" Padding="10,4" FontSize="11" Margin="0,0,6,0">
                                                        <TextBlock>
                                                            <Run Text="▶ 试听" />
                                                        </TextBlock>
                                                    </Button>
                                                    <Button Content="↻" Command="{Binding GenerateCommand}" ToolTip="重新生成配音"
                                                            Visibility="{Binding HasAudio, Converter={StaticResource BoolToVisibility}}"
                                                            Background="#2A2A33" Foreground="#B0B0B0" BorderThickness="0"
                                                            Cursor="Hand" Padding="8,4" FontSize="11" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding DurationText}" FontSize="11" VerticalAlignment="Center"
                                                               Visibility="{Binding HasAudio, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="#FFA94D" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding DurationAligned}" Value="True">
                                                                        <Setter Property="Foreground" Value="{StaticResource SuccessGreenBrush}" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- 手动添加一版 -->
                        <Button Grid.Row="2" Content="+ 手动添加一版" Command="{Binding AddManualCommand}"
                                IsEnabled="{Binding IsNotBusy}" Cursor="Hand" Margin="0,8,0,0" Padding="8,5" FontSize="12"
                                HorizontalAlignment="Stretch" Background="#2A2A33" Foreground="White" BorderThickness="0" />
                    </Grid>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
