<Window x:Class="MixCut.Views.SegmentLibrary.ArrangeOrderSheet"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shared="clr-namespace:MixCut.Views.Shared"
        Title="调整顺序" Width="780" Height="560"
        WindowStartupLocation="CenterOwner" Background="#16161A"
        WindowStyle="ToolWindow" ShowInTaskbar="False"
        x:Name="SheetRoot">
    <Grid Margin="20" DataContext="{Binding ElementName=SheetRoot}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,12">
            <TextBlock Text="调整顺序后生成自定义方案" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
            <TextBlock Text="左右箭头调整每个分镜的位置；点「生成方案」AI 会反推方案信息。"
                       Foreground="#909090" FontSize="11" Margin="0,4,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
            <ItemsControl ItemsSource="{Binding OrderedItems}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="6">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <shared:SegmentCardCompact Grid.Row="0"/>
                            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                                <Button Content="◀" Click="OnMoveLeftClick" Tag="{Binding}"
                                        Width="32" Height="28" Background="#2D2D33" Foreground="White"
                                        BorderThickness="0" Margin="0,0,6,0" Cursor="Hand"
                                        ToolTip="向前移动"/>
                                <Button Content="▶" Click="OnMoveRightClick" Tag="{Binding}"
                                        Width="32" Height="28" Background="#2D2D33" Foreground="White"
                                        BorderThickness="0" Cursor="Hand"
                                        ToolTip="向后移动"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Grid.Row="2" Margin="0,12,0,0">
            <TextBlock Text="{Binding HintText}" Foreground="#909090" FontSize="11" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Click="OnCancelClick"
                        Width="80" Height="32" Background="#2D2D33" Foreground="White"
                        BorderThickness="0" Margin="0,0,8,0" Cursor="Hand"/>
                <Button x:Name="GenerateButton" Content="{Binding GenerateButtonText}" Click="OnGenerateClick"
                        Width="160" Height="32" Background="#7C3AED" Foreground="White"
                        BorderThickness="0" Cursor="Hand"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
