<!--
    组件 Style 库（Stage 0）。
    后续视图直接 Style="{StaticResource PrimaryButtonStyle}" 不再手设属性。

    ⚠ 关键：每个子 ResourceDictionary 必须自己 merge 其依赖（Brushes/Typography/Spacing）。
    WPF 在 LoadOptimizedTemplateContent 加载 ControlTemplate 时使用独立 XAML 上下文，
    依赖父级 MergedDictionary 的 StaticResource 可能返回 UnsetValue 导致渲染崩溃。
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MixCut;component/Resources/Theme/Brushes.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MixCut;component/Resources/Theme/Typography.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MixCut;component/Resources/Theme/Spacing.xaml" />
    </ResourceDictionary.MergedDictionaries>


    <!-- ========== Button ========== -->

    <!-- 主按钮（蓝底白字） -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource AccentBlueBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextOnAccentBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="16,7" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="root" Value="{StaticResource AccentBlueDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter Property="Opacity" TargetName="root" Value="0.85" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" TargetName="root" Value="0.42" />
                            <Setter Property="Cursor" Value="Arrow" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 次按钮（白底蓝字 + 边框） -->
    <Style x:Key="SecondaryButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderHoverBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="14,6" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{StaticResource CornerRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="root" Value="{StaticResource BgSecondaryBrush}" />
                            <Setter Property="BorderBrush" TargetName="root" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" TargetName="root" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 危险按钮（红底白字） -->
    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
        <Setter Property="Background" Value="{StaticResource DangerRedBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusMd}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="root" Value="{StaticResource DangerRedDarkBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" TargetName="root" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Ghost 按钮（透明背景，hover 时浅色） -->
    <Style x:Key="GhostButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="10,5" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusXs}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="root" Value="{StaticResource BgTertiaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 图标小按钮（用于 +/- ⋯ 等紧凑按钮） -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgQuaternaryBrush}" />
        <Setter Property="Foreground" Value="{StaticResource TextTertiaryBrush}" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="root"
                            Background="{TemplateBinding Background}"
                            CornerRadius="{StaticResource CornerRadiusXs}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" TargetName="root" Value="{StaticResource BgTertiaryBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== Card Border ========== -->
    <Style x:Key="CardBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusLg}" />
        <Setter Property="Padding" Value="10" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
    </Style>

    <Style x:Key="CardBorderSelectedStyle" TargetType="Border" BasedOn="{StaticResource CardBorderStyle}">
        <Setter Property="Background" Value="{StaticResource AccentBlueAlpha10Brush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
        <Setter Property="BorderThickness" Value="1.5" />
    </Style>

    <!-- ========== TextBox 占位辅助（PlaceholderText helper） ========== -->
    <Style x:Key="InlineEditTextBoxStyle" TargetType="TextBox">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeMicro}" />
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}" />
        <Setter Property="TextAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Width" Value="36" />
        <Setter Property="Padding" Value="0" />
    </Style>

    <!-- ========== Chip/Tag/Badge ========== -->
    <Style x:Key="ChipBorderStyle" TargetType="Border">
        <Setter Property="CornerRadius" Value="{StaticResource CornerRadiusPill}" />
        <Setter Property="Padding" Value="7,2" />
        <Setter Property="Margin" Value="0,0,4,4" />
    </Style>

    <!-- ========== ScrollViewer 轻量化样式 ========== -->
    <Style x:Key="ThinScrollViewerStyle" TargetType="ScrollViewer">
        <Setter Property="VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="CanContentScroll" Value="True" />
    </Style>

</ResourceDictionary>
