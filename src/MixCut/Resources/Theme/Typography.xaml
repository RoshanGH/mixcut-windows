<!--
    字号 token（FontSize 频次：11(105) / 12(71) / 10(56) / 14(30) / 13(21) / 9(15) / 22(10) / 18(8) / 16(7) / 20(6) / 24(5) / 36(4)）
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 字号阶梯 -->
    <sys:Double x:Key="FontSizeTiny">8</sys:Double>
    <sys:Double x:Key="FontSizeMicro">9</sys:Double>
    <sys:Double x:Key="FontSizeCaption">10</sys:Double>
    <sys:Double x:Key="FontSizeBodySmall">11</sys:Double>
    <sys:Double x:Key="FontSizeBody">12</sys:Double>
    <sys:Double x:Key="FontSizeBodyLarge">13</sys:Double>
    <sys:Double x:Key="FontSizeSubtitle">14</sys:Double>
    <sys:Double x:Key="FontSizeH3">16</sys:Double>
    <sys:Double x:Key="FontSizeH2">18</sys:Double>
    <sys:Double x:Key="FontSizeH1">22</sys:Double>
    <sys:Double x:Key="FontSizeHero">28</sys:Double>
    <sys:Double x:Key="FontSizeDisplay">36</sys:Double>

    <!-- 字号变体 -->
    <sys:Double x:Key="FontSizeBadgeSmall">20</sys:Double>
    <sys:Double x:Key="FontSizeBadgeLarge">24</sys:Double>
    <sys:Double x:Key="FontSizeNumber">42</sys:Double>
    <sys:Double x:Key="FontSizeEmojiHero">50</sys:Double>

    <!-- 等宽字体（用于时间戳、字符计数、码率等） -->
    <FontFamily x:Key="FontFamilyMono">Consolas, Cascadia Mono, "Courier New", monospace</FontFamily>

</ResourceDictionary>
