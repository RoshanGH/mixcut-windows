<!--
    控件级现代化模板（Stage UI 优化）。
    - 细窄滚动条：替换 WPF 默认笨重灰滚动条，对齐剪映/VSCode 的 overlay 细条观感。
    - 侧边栏导航/项目项：去掉系统蓝色选中框，改品牌色圆角高亮 + hover 反馈 + 平滑过渡。

    ⚠ 与 Styles.xaml 同约定：本字典自己 merge 依赖（Brushes），避免 ControlTemplate
       在 LoadOptimizedTemplateContent 阶段 StaticResource 解析为 UnsetValue。
-->
<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="pack://application:,,,/MixCut;component/Resources/Theme/Brushes.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MixCut;component/Resources/Theme/Typography.xaml" />
        <ResourceDictionary Source="pack://application:,,,/MixCut;component/Resources/Theme/Spacing.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <!-- ========== 细窄滚动条 ========== -->

    <!-- 滚动条滑块：圆角胶囊，hover/拖动时加深 -->
    <Style x:Key="ScrollThumbStyle" TargetType="Thumb">
        <Setter Property="Background" Value="#C2C2CC" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Border x:Name="tb" CornerRadius="4" Background="{TemplateBinding Background}" Margin="2" />
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="tb" Property="Background" Value="#9A9AA6" />
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="tb" Property="Background" Value="#7E7E8A" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 透明分页按钮（保留点击轨道翻页能力，但不可见，无箭头） -->
    <Style x:Key="ScrollPageButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 垂直滚动条模板 -->
    <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Background="Transparent">
            <Track x:Name="PART_Track" IsDirectionReversed="True">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButtonStyle}" Command="ScrollBar.PageUpCommand" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButtonStyle}" Command="ScrollBar.PageDownCommand" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- 水平滚动条模板 -->
    <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
        <Grid Background="Transparent">
            <Track x:Name="PART_Track">
                <Track.DecreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButtonStyle}" Command="ScrollBar.PageLeftCommand" />
                </Track.DecreaseRepeatButton>
                <Track.Thumb>
                    <Thumb Style="{StaticResource ScrollThumbStyle}" />
                </Track.Thumb>
                <Track.IncreaseRepeatButton>
                    <RepeatButton Style="{StaticResource ScrollPageButtonStyle}" Command="ScrollBar.PageRightCommand" />
                </Track.IncreaseRepeatButton>
            </Track>
        </Grid>
    </ControlTemplate>

    <!-- 隐式 ScrollBar 样式：默认垂直 10px 细条，水平时换模板 + 高度 10px -->
    <Style TargetType="ScrollBar">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Width" Value="10" />
        <Setter Property="MinWidth" Value="10" />
        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}" />
        <Style.Triggers>
            <Trigger Property="Orientation" Value="Horizontal">
                <Setter Property="Width" Value="Auto" />
                <Setter Property="MinWidth" Value="0" />
                <Setter Property="Height" Value="10" />
                <Setter Property="MinHeight" Value="10" />
                <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ========== 侧边栏导航 / 项目列表项 ==========
         去系统选中蓝框，改品牌色圆角高亮：默认透明、hover 浅灰、选中浅蓝底 + 左侧蓝条。 -->
    <Style x:Key="SidebarListBoxItemStyle" TargetType="ListBoxItem">
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="Margin" Value="0,1" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="7"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <Grid>
                            <Border x:Name="accent" Width="3" CornerRadius="2" HorizontalAlignment="Left"
                                    Margin="-4,2,0,2" Background="{StaticResource AccentBlueBrush}"
                                    Opacity="0" />
                            <ContentPresenter VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BgTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBlueLightBrush}" />
                            <Setter TargetName="accent" Property="Opacity" Value="1" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
                            <Setter Property="TextElement.FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ========== 现代化 CheckBox ==========
         去 stock Aero 勾选框，改圆角方块：未选白底灰边，hover 蓝边，选中蓝底白勾。 -->
    <Style TargetType="CheckBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <StackPanel Orientation="Horizontal" Background="Transparent">
                        <Border x:Name="box" Width="16" Height="16" CornerRadius="4"
                                Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderStrongBrush}" BorderThickness="1.3"
                                VerticalAlignment="Center" SnapsToDevicePixels="True">
                            <Path x:Name="check" Width="10" Height="10" Stretch="Uniform"
                                  Data="M2,6 L5,9 L10,2" Stroke="White" StrokeThickness="1.6"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Opacity="0" />
                        </Border>
                        <ContentPresenter Margin="8,0,0,0" VerticalAlignment="Center"
                                          RecognizesAccessKey="True" />
                    </StackPanel>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="check" Property="Opacity" Value="1" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="{x:Null}">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== 现代化 ComboBox（非可编辑） ==========
         扁平圆角框 + 自定义箭头，hover/打开时蓝边；下拉弹层圆角 + 阴影 + 项 hover/选中态。 -->
    <Style x:Key="ComboToggleButtonStyle" TargetType="ToggleButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="ModernComboBoxItemStyle" TargetType="ComboBoxItem">
        <Setter Property="Padding" Value="10,7" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBoxItem">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="6"
                            Margin="4,1" Padding="{TemplateBinding Padding}">
                        <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource BgTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource AccentBlueLightBrush}" />
                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
                            <Setter Property="FontWeight" Value="SemiBold" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="ComboBox">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="{StaticResource BgPrimaryBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource BorderStrongBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="12,7" />
        <Setter Property="Height" Value="36" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="ItemContainerStyle" Value="{StaticResource ModernComboBoxItemStyle}" />
        <Setter Property="ScrollViewer.CanContentScroll" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8" SnapsToDevicePixels="True" />
                        <ToggleButton Style="{StaticResource ComboToggleButtonStyle}"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" />
                        <Grid Margin="{TemplateBinding Padding}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <ContentPresenter x:Name="content" Grid.Column="0"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                              VerticalAlignment="Center" HorizontalAlignment="Left"
                                              IsHitTestVisible="False" />
                            <!-- 可编辑模式（如设置页模型名输入）：ComboBox 自动接管 PART_EditableTextBox -->
                            <TextBox x:Name="PART_EditableTextBox" Grid.Column="0"
                                     Style="{x:Null}" Background="Transparent" BorderThickness="0"
                                     Padding="0" VerticalAlignment="Center" VerticalContentAlignment="Center"
                                     Foreground="{TemplateBinding Foreground}"
                                     Visibility="Hidden" Focusable="True" />
                            <Path Grid.Column="1" x:Name="arrow" VerticalAlignment="Center"
                                  Margin="8,0,0,0" Width="11" Height="7" Stretch="Fill"
                                  Data="M0,0 L5.5,6 L11,0" Fill="{StaticResource TextTertiaryBrush}"
                                  IsHitTestVisible="False" />
                        </Grid>
                        <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                               IsOpen="{TemplateBinding IsDropDownOpen}" Focusable="False"
                               PopupAnimation="Fade" Margin="0">
                            <Border Margin="0,4,0,8" Background="{StaticResource BgPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                                    CornerRadius="8"
                                    MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                    MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.16" BlurRadius="14" ShadowDepth="2" />
                                </Border.Effect>
                                <ScrollViewer Margin="0,3">
                                    <ItemsPresenter SnapsToDevicePixels="True" />
                                </ScrollViewer>
                            </Border>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEditable" Value="True">
                            <Setter TargetName="content" Property="Visibility" Value="Collapsed" />
                            <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            <Setter Property="Cursor" Value="IBeam" />
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsDropDownOpen" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="arrow" Property="Fill" Value="{StaticResource AccentBlueBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ========== 现代化 ToolTip ==========
         去 stock 系统提示（浅黄/直角/系统字），改深色圆角卡片 + 阴影，与整体设计系统一致。 -->
    <Style TargetType="ToolTip">
        <Setter Property="Foreground" Value="White" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodySmall}" />
        <Setter Property="HasDropShadow" Value="True" />
        <Setter Property="Padding" Value="10,6" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToolTip">
                    <Border Background="#F21F1F23" CornerRadius="7"
                            Padding="{TemplateBinding Padding}" MaxWidth="320">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.22" BlurRadius="12" ShadowDepth="2" />
                        </Border.Effect>
                        <ContentPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ========== 现代化 Slider（横向）==========
         4px 圆角轨道 + 蓝色已填充段 + 白色圆形 thumb（带阴影），hover/拖动放大。
         用于视频进度条（InlineVideoPlayer）与生成方案数量（GenerateSchemeDialog）。
         保留 PART_Track + Thumb，确保 Thumb.DragStarted/DragCompleted 事件不破。 -->
    <Style x:Key="ModernSliderThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="15" />
        <Setter Property="Height" Value="15" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Grid>
                        <Ellipse x:Name="el" Fill="White" Stroke="{StaticResource AccentBlueBrush}"
                                 StrokeThickness="2" RenderTransformOrigin="0.5,0.5">
                            <Ellipse.Effect>
                                <DropShadowEffect Color="Black" Opacity="0.22" BlurRadius="5" ShadowDepth="1" />
                            </Ellipse.Effect>
                            <Ellipse.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1" />
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="el" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.18" ScaleY="1.18" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="el" Property="Fill" Value="{StaticResource AccentBlueBrush}" />
                            <Setter TargetName="el" Property="RenderTransform">
                                <Setter.Value>
                                    <ScaleTransform ScaleX="1.18" ScaleY="1.18" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderFillButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                            Background="{StaticResource AccentBlueBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SliderTrackButtonStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Slider">
        <Setter Property="MinHeight" Value="18" />
        <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center" MinHeight="18" Background="Transparent">
                        <Border Height="4" CornerRadius="2" VerticalAlignment="Center"
                                Background="{StaticResource BorderStrongBrush}" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderFillButtonStyle}"
                                              Command="Slider.DecreaseLarge" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ModernSliderThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource SliderTrackButtonStyle}"
                                              Command="Slider.IncreaseLarge" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ========== 现代化 ContextMenu / MenuItem ==========
         去 stock 系统菜单（灰勾选槽、直角、系统配色），改白色圆角卡片 + 阴影 + 项圆角 hover 高亮 +
         品牌蓝勾选。全局生效：分镜库「更多」语义/位置勾选菜单、卡片右键、项目右键菜单都受益。
         统一模板兼容叶子项（可勾选/普通）与带子菜单的 SubmenuHeader（箭头 + 弹层）。 -->
    <Style TargetType="ContextMenu">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContextMenu">
                    <Border Background="{StaticResource BgPrimaryBrush}"
                            BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                            CornerRadius="9" Padding="4" Margin="6">
                        <Border.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.18" BlurRadius="16" ShadowDepth="2" />
                        </Border.Effect>
                        <ItemsPresenter SnapsToDevicePixels="True" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="Separator" x:Key="{x:Static MenuItem.SeparatorStyleKey}">
        <Setter Property="Height" Value="1" />
        <Setter Property="Margin" Value="8,5" />
        <Setter Property="Background" Value="{StaticResource BorderSubtleBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Separator">
                    <Border Height="1" Background="{TemplateBinding Background}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="MenuItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Padding" Value="8,6" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="MenuItem">
                    <Border x:Name="bg" Background="Transparent" CornerRadius="6" Margin="2,1"
                            Padding="{TemplateBinding Padding}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="22" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <!-- 勾选标记（可勾选项选中时显示）/ Icon -->
                            <Path x:Name="check" Grid.Column="0" Width="12" Height="12" Stretch="Uniform"
                                  Data="M2,6 L5,9 L10,2" Stroke="{StaticResource AccentBlueBrush}"
                                  StrokeThickness="1.8" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" VerticalAlignment="Center" HorizontalAlignment="Center"
                                  Visibility="Collapsed" />
                            <ContentPresenter x:Name="icon" Grid.Column="0" ContentSource="Icon"
                                              VerticalAlignment="Center" HorizontalAlignment="Center" />
                            <ContentPresenter Grid.Column="1" ContentSource="Header" RecognizesAccessKey="True"
                                              VerticalAlignment="Center" Margin="2,0,0,0" />
                            <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                       Foreground="{StaticResource TextQuaternaryBrush}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       VerticalAlignment="Center" Margin="16,0,0,0" />
                            <Path x:Name="arrow" Grid.Column="3" Width="6" Height="9" Stretch="Fill"
                                  Data="M0,0 L6,4.5 L0,9" Fill="{StaticResource TextTertiaryBrush}"
                                  VerticalAlignment="Center" Margin="10,0,0,0" Visibility="Collapsed" />
                            <Popup x:Name="PART_Popup" Placement="Right" VerticalOffset="-5" HorizontalOffset="-2"
                                   IsOpen="{TemplateBinding IsSubmenuOpen}" AllowsTransparency="True"
                                   Focusable="False" PopupAnimation="Fade">
                                <Border Background="{StaticResource BgPrimaryBrush}"
                                        BorderBrush="{StaticResource BorderPrimaryBrush}" BorderThickness="1"
                                        CornerRadius="9" Padding="4" Margin="6">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black" Opacity="0.18" BlurRadius="16" ShadowDepth="2" />
                                    </Border.Effect>
                                    <ItemsPresenter SnapsToDevicePixels="True" />
                                </Border>
                            </Popup>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsCheckable" Value="True">
                            <Setter TargetName="icon" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="check" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Role" Value="SubmenuHeader">
                            <Setter TargetName="arrow" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="Role" Value="TopLevelHeader">
                            <Setter TargetName="arrow" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="IsHighlighted" Value="True">
                            <Setter TargetName="bg" Property="Background" Value="{StaticResource BgTertiaryBrush}" />
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.4" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <!-- ========== 媒体进度条 Slider（深色叠层专用）==========
         视频播放控制栏在半透明黑底上：轨道用半透明白、已播段用品牌蓝、thumb 小白点。
         比通用浅色 Slider 在深色视频上更清晰好看。 -->
    <Style x:Key="MediaSliderThumbStyle" TargetType="Thumb">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Width" Value="11" />
        <Setter Property="Height" Value="11" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Thumb">
                    <Ellipse x:Name="el" Fill="White" RenderTransformOrigin="0.5,0.5">
                        <Ellipse.Effect>
                            <DropShadowEffect Color="Black" Opacity="0.4" BlurRadius="4" ShadowDepth="0" />
                        </Ellipse.Effect>
                        <Ellipse.RenderTransform>
                            <ScaleTransform ScaleX="1" ScaleY="1" />
                        </Ellipse.RenderTransform>
                    </Ellipse>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="el" Property="RenderTransform">
                                <Setter.Value><ScaleTransform ScaleX="1.3" ScaleY="1.3" /></Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsDragging" Value="True">
                            <Setter TargetName="el" Property="RenderTransform">
                                <Setter.Value><ScaleTransform ScaleX="1.3" ScaleY="1.3" /></Setter.Value>
                            </Setter>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MediaSliderFillStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                            Background="{StaticResource AccentBlueBrush}" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MediaSliderTrackStyle" TargetType="RepeatButton">
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Focusable" Value="False" />
        <Setter Property="IsTabStop" Value="False" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="RepeatButton">
                    <Border Background="Transparent" />
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="MediaSliderStyle" TargetType="Slider">
        <Setter Property="MinHeight" Value="16" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Slider">
                    <Grid VerticalAlignment="Center" MinHeight="16" Background="Transparent">
                        <Border Height="3" CornerRadius="1.5" VerticalAlignment="Center"
                                Background="#5AFFFFFF" />
                        <Track x:Name="PART_Track">
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MediaSliderFillStyle}" Command="Slider.DecreaseLarge" />
                            </Track.DecreaseRepeatButton>
                            <Track.Thumb>
                                <Thumb Style="{StaticResource MediaSliderThumbStyle}" />
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Style="{StaticResource MediaSliderTrackStyle}" Command="Slider.IncreaseLarge" />
                            </Track.IncreaseRepeatButton>
                        </Track>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
